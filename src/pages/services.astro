---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import PageHero from '../components/PageHero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CtaSection from '../components/CtaSection.astro';
import { services } from '../data/services';

const steps = [
  {
    number: '01',
    title: 'Écoute',
    description: 'On échange sur vos besoins, vos objectifs et votre cible. Je vous pose les bonnes questions.',
  },
  {
    number: '02',
    title: 'Conception',
    description: "Je conçois la structure et le design de votre site. Vous validez avant chaque étape.",
  },
  {
    number: '03',
    title: 'Développement',
    description: 'Je développe votre site avec les meilleures pratiques : rapide, accessible, bien référencé.',
  },
  {
    number: '04',
    title: 'Livraison',
    description: 'Votre site est mis en ligne. Je reste disponible pour le faire évoluer.',
  },
];
---

<BaseLayout
  title="Services — Création de sites web, refonte | Tristan Labbé"
  description="Création de sites vitrines, refonte de sites existants pour TPE, artisans et associations. Devis gratuit et personnalisé."
>
  <!-- Hero -->
  <PageHero
    title="Mes services"
    subtitle="Écoute du besoin, propositions techniques, mise en œuvre adaptée. Chaque projet est unique, chaque devis est personnalisé."
  />

  <hr class="separator-gradient" />

  <!-- Services détaillés -->
  <section class="py-24 lg:py-32 bg-surface dark:bg-[var(--color-dark-bg)]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-3 gap-8 stagger-children">
        {services.map((service) => (
          <ScrollReveal>
            <ServiceCard {...service} />
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>

  <hr class="separator-gradient" />

  <!-- Processus de travail -->
  <section class="py-24 lg:py-32 bg-surface-alt dark:bg-[var(--color-dark-surface)]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <ScrollReveal>
        <SectionHeading title="Comment ça se passe ?" subtitle="Un processus clair et transparent, de l'écoute à la livraison." />
      </ScrollReveal>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 stagger-children">
        {steps.map((step) => (
          <ScrollReveal>
            <div class="card-premium text-center p-8">
              <div class="text-5xl font-bold gradient-text mb-4">{step.number}</div>
              <h3 class="text-lg font-bold text-primary dark:text-white mb-2">{step.title}</h3>
              <p class="text-sm text-text-muted dark:text-[var(--color-dark-text-muted)]">{step.description}</p>
            </div>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CtaSection
    title="Prêt à lancer votre projet ?"
    subtitle="Décrivez-moi votre besoin, je vous recontacte avec un devis gratuit et personnalisé."
    buttonText="Demander un devis gratuit"
  />
</BaseLayout>
