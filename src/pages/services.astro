---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ScrollReveal from '../components/ScrollReveal.astro';

const services = [
  {
    title: 'Site vitrine',
    description: 'Un site professionnel pour présenter votre activité et vos services. J\'écoute votre besoin, je vous propose une solution technique adaptée et je la mets en œuvre.',
    icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" /></svg>',
    mention: 'Sur devis',
  },
  {
    title: 'Refonte de site existant',
    description: "Votre site est vieillissant ou ne vous ressemble plus ? Je le repense techniquement et lui donne un second souffle, en conservant votre identité.",
    icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" /></svg>',
    mention: 'Sur devis',
  },
  {
    title: 'Maintenance & évolution',
    description: "Mises à jour, corrections techniques, évolutions fonctionnelles : je reste votre interlocuteur unique après la livraison.",
    icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75a4.5 4.5 0 01-4.884 4.484c-1.076-.091-2.264.071-2.95.904l-7.152 8.684a2.548 2.548 0 11-3.586-3.586l8.684-7.152c.833-.686.995-1.874.904-2.95a4.5 4.5 0 016.336-4.486l-3.276 3.276a2.25 2.25 0 003.182 3.182l3.276-3.276c.256.565.398 1.192.398 1.852z" /></svg>',
    mention: 'Sur devis',
  },
];

const steps = [
  {
    number: '01',
    title: 'Écoute',
    description: 'On échange sur vos besoins, vos objectifs et votre cible. Je vous pose les bonnes questions.',
  },
  {
    number: '02',
    title: 'Conception',
    description: "Je conçois la structure et le design de votre site. Vous validez avant chaque étape.",
  },
  {
    number: '03',
    title: 'Développement',
    description: 'Je développe votre site avec les meilleures pratiques : rapide, accessible, bien référencé.',
  },
  {
    number: '04',
    title: 'Livraison',
    description: 'Votre site est mis en ligne. Je reste disponible pour le faire évoluer.',
  },
];
---

<BaseLayout
  title="Services — Création de sites web, refonte, maintenance | Tristan Labbé"
  description="Création de sites vitrines, refonte de sites existants et maintenance pour TPE, artisans et associations. Devis gratuit et personnalisé."
>
  <!-- Hero -->
  <section class="relative py-24 lg:py-32 overflow-hidden">
    <div class="absolute inset-0 cta-gradient"></div>
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot; fill=&quot;%23ffffff&quot;/%3E%3C/g%3E%3C/svg%3E');"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-white">
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-6 hero-animate">Mes services</h1>
      <p class="text-lg text-white/70 max-w-2xl mx-auto hero-animate hero-animate-delay-1">
        Écoute du besoin, propositions techniques, mise en œuvre adaptée. Chaque projet est unique, chaque devis est personnalisé.
      </p>
    </div>
  </section>

  <hr class="separator-gradient" />

  <!-- Services détaillés -->
  <section class="py-24 lg:py-32 bg-surface dark:bg-[var(--color-dark-bg)]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-3 gap-8 stagger-children">
        {services.map((service) => (
          <ScrollReveal>
            <div class="card-premium p-8">
              <div class="icon-glow w-14 h-14 rounded-xl bg-accent/10 flex items-center justify-center mb-6 text-accent" set:html={service.icon} />
              <h3 class="text-xl font-bold text-primary dark:text-white mb-3">{service.title}</h3>
              <p class="text-text-muted dark:text-[var(--color-dark-text-muted)] text-sm leading-relaxed mb-5">{service.description}</p>
              <span class="inline-block text-xs font-semibold text-accent-text dark:text-accent-text-dark bg-accent/10 px-3 py-1.5 rounded-full">
                {service.mention}
              </span>
            </div>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>

  <hr class="separator-gradient" />

  <!-- Processus de travail -->
  <section class="py-24 lg:py-32 bg-surface-alt dark:bg-[var(--color-dark-surface)]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <ScrollReveal>
        <SectionHeading title="Comment ça se passe ?" subtitle="Un processus clair et transparent, de l'écoute à la livraison." />
      </ScrollReveal>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 stagger-children">
        {steps.map((step) => (
          <ScrollReveal>
            <div class="card-premium text-center p-8">
              <div class="text-5xl font-bold gradient-text mb-4">{step.number}</div>
              <h3 class="text-lg font-bold text-primary dark:text-white mb-2">{step.title}</h3>
              <p class="text-sm text-text-muted dark:text-[var(--color-dark-text-muted)]">{step.description}</p>
            </div>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 cta-gradient text-white text-center relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot; fill=&quot;%23ffffff&quot;/%3E%3C/g%3E%3C/svg%3E');"></div>
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <ScrollReveal>
        <h2 class="text-3xl md:text-5xl font-bold mb-6">Prêt à lancer votre projet ?</h2>
        <p class="text-lg text-white/70 mb-10">
          Décrivez-moi votre besoin, je vous recontacte avec un devis gratuit et personnalisé.
        </p>
        <a href="/portfolio/contact/" class="btn-glow group inline-flex items-center gap-2 px-8 py-4 bg-white text-primary font-semibold rounded-xl hover:bg-white/90 shadow-lg shadow-black/10 transition-all duration-300">
          Demander un devis gratuit
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </ScrollReveal>
    </div>
  </section>
</BaseLayout>
