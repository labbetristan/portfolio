---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import PageHero from '../components/PageHero.astro';
---

<BaseLayout
  title="Contact — Devis gratuit | Tristan Labbé"
  description="Une idée, un projet, une question ? Contactez-moi pour un devis gratuit et personnalisé."
>
  <!-- Hero -->
  <PageHero
    title="Parlons de votre projet"
    subtitle="Une idée, un projet, une question ? Décrivez-moi votre besoin, je vous réponds avec une première estimation gratuite."
  />

  <hr class="separator-gradient" />

  <!-- Contact form -->
  <section class="py-24 lg:py-32 bg-surface dark:bg-[var(--color-dark-bg)]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-5 gap-12">
        <!-- Info column -->
        <ScrollReveal class="lg:col-span-2">
          <div class="space-y-8">
            <div>
              <h2 class="text-2xl font-bold text-primary dark:text-white mb-4">Informations</h2>
              <p class="text-text-muted dark:text-[var(--color-dark-text-muted)] leading-relaxed">
                Je travaille entièrement à distance avec des clients partout en France. N'hésitez pas à me décrire votre projet en quelques lignes.
              </p>
            </div>

            <div class="space-y-4">
              <div class="card-premium p-4 flex items-start gap-3">
                <div class="icon-glow w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center text-accent shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-text dark:text-[var(--color-dark-text)]">Localisation</h3>
                  <p class="text-sm text-text-muted dark:text-[var(--color-dark-text-muted)]">100% à distance — partout en France</p>
                </div>
              </div>

              <div class="card-premium p-4 flex items-start gap-3">
                <div class="icon-glow w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center text-accent shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-text dark:text-[var(--color-dark-text)]">Délai de réponse</h3>
                  <p class="text-sm text-text-muted dark:text-[var(--color-dark-text-muted)]">Avec une première estimation gratuite</p>
                </div>
              </div>

              <div class="card-premium p-4 flex items-start gap-3">
                <div class="icon-glow w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center text-accent shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-text dark:text-[var(--color-dark-text)]">Tarification</h3>
                  <p class="text-sm text-text-muted dark:text-[var(--color-dark-text-muted)]">Devis gratuit et personnalisé</p>
                </div>
              </div>
            </div>
          </div>
        </ScrollReveal>

        <!-- Form column — pas d'animation : prêt à l'interaction immédiate -->
        <div class="lg:col-span-3">
          <div class="card-premium p-8">
            <ContactForm />
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
