---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ScrollReveal from '../components/ScrollReveal.astro';

const projects = [
  {
    title: 'Les Butineuses des 1000 fleurs',
    description: "Site vitrine pour une association apicole. Présentation de l'activité, des produits et des événements.",
    href: 'https://lesbutineusesdes1000fleurs.fr/',
    image: '/portfolio/images/portfolio/butineuses.webp',
  },
  {
    title: 'Soirée Guitare',
    description: 'Site événementiel pour un concert. Page unique, design immersif, informations pratiques.',
    href: 'https://labbetristan.github.io/soireeGuitare/',
    image: '/portfolio/images/portfolio/soiree-guitare.webp',
  },
  {
    title: 'Site MoS-T',
    description: 'Site vitrine multilingue français / anglais. Accessibilité et internationalisation.',
    href: 'https://aurelieleborgne.github.io/site-MoS-T/fr/',
    image: '/portfolio/images/portfolio/mos-t.webp',
  },
];
---

<BaseLayout
  title="Réalisations — Sites web pour TPE et associations | Tristan Labbé"
  description="Découvrez mes réalisations : sites vitrines pour associations, événements et entreprises. Chaque projet est conçu sur-mesure."
>
  <!-- Hero -->
  <section class="relative py-24 lg:py-32 overflow-hidden">
    <div class="absolute inset-0 cta-gradient"></div>
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot; fill=&quot;%23ffffff&quot;/%3E%3C/g%3E%3C/svg%3E');"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-white">
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-6 hero-animate">Mes réalisations</h1>
      <p class="text-lg text-white/70 max-w-2xl mx-auto hero-animate hero-animate-delay-1">
        Chaque projet est conçu sur-mesure pour répondre aux besoins spécifiques de mes clients. Cliquez pour visiter les sites.
      </p>
    </div>
  </section>

  <hr class="separator-gradient" />

  <!-- Portfolio grid -->
  <section class="py-24 lg:py-32 bg-surface dark:bg-[var(--color-dark-bg)]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 stagger-children">
        {projects.map((project) => (
          <ScrollReveal>
            <a href={project.href} target="_blank" rel="noopener noreferrer" class="card-premium group block overflow-hidden">
              <div class="relative overflow-hidden">
                <img src={project.image} alt={`Aperçu du site ${project.title}`} class="w-full aspect-[8/5] object-cover object-top transition-transform duration-500 group-hover:scale-105" loading="lazy" width="800" height="500" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                <div class="absolute top-3 right-3 w-8 h-8 rounded-full bg-white/90 dark:bg-[var(--color-dark-card)]/90 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-300 translate-y-2 group-hover:translate-y-0">
                  <svg class="w-3.5 h-3.5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
                  </svg>
                </div>
              </div>
              <div class="p-6">
                <h3 class="text-lg font-bold text-primary dark:text-white mb-2 group-hover:text-accent transition-colors">{project.title}</h3>
                <p class="text-text-muted dark:text-[var(--color-dark-text-muted)] text-sm leading-relaxed">{project.description}</p>
              </div>
            </a>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 cta-gradient text-white text-center relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot; fill=&quot;%23ffffff&quot;/%3E%3C/g%3E%3C/svg%3E');"></div>
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <ScrollReveal>
        <h2 class="text-3xl md:text-5xl font-bold mb-6">Votre projet pourrait être le prochain</h2>
        <p class="text-lg text-white/70 mb-10">
          Vous avez un projet en tête ? Parlons-en et donnons vie à vos idées.
        </p>
        <a href="/portfolio/contact/" class="btn-glow group inline-flex items-center gap-2 px-8 py-4 bg-white text-primary font-semibold rounded-xl hover:bg-white/90 shadow-lg shadow-black/10 transition-all duration-300">
          Discutons de votre projet
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </ScrollReveal>
    </div>
  </section>
</BaseLayout>
