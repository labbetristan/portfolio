---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import PageHero from '../components/PageHero.astro';
import PortfolioCard from '../components/PortfolioCard.astro';
import CtaSection from '../components/CtaSection.astro';
import { projects } from '../data/portfolio';
---

<BaseLayout
  title="Réalisations — Sites web pour TPE et associations | Tristan Labbé"
  description="Découvrez mes réalisations : sites vitrines pour associations, événements et entreprises. Chaque projet est conçu sur-mesure."
>
  <!-- Hero -->
  <PageHero
    title="Mes réalisations"
    subtitle="Chaque projet est conçu sur-mesure pour répondre aux besoins spécifiques de mes clients. Cliquez pour visiter les sites."
  />

  <hr class="separator-gradient" />

  <!-- Portfolio grid -->
  <section class="py-24 lg:py-32 bg-surface dark:bg-[var(--color-dark-bg)]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 stagger-children">
        {projects.map((project) => (
          <ScrollReveal>
            <PortfolioCard {...project} />
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CtaSection
    title="Votre projet pourrait être le prochain"
    subtitle="Vous avez un projet en tête ? Parlons-en et donnons vie à vos idées."
    buttonText="Discutons de votre projet"
  />
</BaseLayout>
