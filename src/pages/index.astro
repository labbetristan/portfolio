---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Card from '../components/Card.astro';
import ScrollReveal from '../components/ScrollReveal.astro';

const services = [
  {
    title: 'Site vitrine',
    description: 'Un site professionnel pour présenter votre activité, vos services et vos coordonnées.',
    icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" /></svg>',
  },
  {
    title: 'Refonte de site',
    description: 'Votre site est vieillissant ? Je le modernise en conservant votre identité et votre référencement.',
    icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" /></svg>',
  },
  {
    title: 'Maintenance & évolution',
    description: 'Mises à jour, ajout de contenu, corrections techniques : je reste votre interlocuteur unique.',
    icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-5.1-5.1a1.5 1.5 0 010-2.12l.88-.88a1.5 1.5 0 012.12 0l2.1 2.1 5.1-5.1a1.5 1.5 0 012.12 0l.88.88a1.5 1.5 0 010 2.12l-7.98 7.98a1.5 1.5 0 01-2.12 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75a4.5 4.5 0 01-4.884 4.484c-1.076-.091-2.264.071-2.95.904l-7.152 8.684a2.548 2.548 0 11-3.586-3.586l8.684-7.152c.833-.686.995-1.874.904-2.95a4.5 4.5 0 016.336-4.486l-3.276 3.276a2.25 2.25 0 003.182 3.182l3.276-3.276c.256.565.398 1.192.398 1.852z" /></svg>',
  },
];

const portfolio = [
  {
    title: 'Les Butineuses des 1000 fleurs',
    description: 'Site vitrine pour une association apicole.',
    href: 'https://lesbutineusesdes1000fleurs.fr/',
  },
  {
    title: 'Soirée Guitare',
    description: 'Site événementiel pour un concert.',
    href: 'https://labbetristan.github.io/soireeGuitare/',
  },
  {
    title: 'Site MoS-T',
    description: 'Site vitrine multilingue français / anglais.',
    href: 'https://aurelieleborgne.github.io/site-MoS-T/fr/',
  },
];

const stats = [
  { value: '10+', label: "ans d'expérience" },
  { value: '100%', label: 'à distance' },
  { value: '24h', label: 'délai de réponse' },
];
---

<BaseLayout
  title="Tristan Labbé — Développeur web freelance | Sites sur-mesure pour TPE et artisans"
  description="Développeur web full-stack indépendant. Création de sites vitrines, refonte et maintenance pour TPE, artisans et associations. Devis gratuit sous 24h."
>
  <!-- ===== HERO ===== -->
  <section class="relative min-h-[90vh] flex items-center justify-center bg-gradient-to-br from-primary via-primary-light to-accent overflow-hidden">
    <!-- Decorative bg elements -->
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-20 left-10 w-72 h-72 bg-white rounded-full blur-3xl"></div>
      <div class="absolute bottom-20 right-10 w-96 h-96 bg-accent rounded-full blur-3xl"></div>
    </div>

    <div class="relative z-10 text-center px-4 sm:px-6 lg:px-8 max-w-4xl mx-auto">
      <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
        Des sites web sur-mesure pour les <span class="text-accent-hover brightness-150">TPE, artisans et associations</span>.
      </h1>
      <p class="text-lg sm:text-xl text-white/80 max-w-2xl mx-auto mb-10">
        Clairs, efficaces et livrés sans jargon — par un professionnel qui connaît vos contraintes.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <Button href="/portfolio/portfolio/" variant="primary" size="lg">
          Voir mes réalisations
        </Button>
        <Button href="/portfolio/contact/" variant="outline" size="lg" class="border-white text-white hover:bg-white hover:text-primary">
          Me contacter
        </Button>
      </div>
    </div>
  </section>

  <!-- ===== À PROPOS ===== -->
  <section class="py-20 lg:py-28 bg-surface dark:bg-[var(--color-dark-bg)]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <ScrollReveal>
        <SectionHeading title="À propos" />
      </ScrollReveal>

      <div class="grid lg:grid-cols-5 gap-12 items-center">
        <!-- Text -->
        <ScrollReveal class="lg:col-span-3">
          <div class="space-y-5 text-text dark:text-[var(--color-dark-text)] leading-relaxed">
            <p>
              Développeur web full-stack et chef de projets informatique avec plus de <strong>10 ans d'expérience</strong>, je mets mes compétences au service des petites structures qui méritent un site à la hauteur de leur activité.
            </p>
            <p>
              Mon parcours en gestion de projet me permet de cadrer chaque mission avec rigueur : <strong>délais respectés, budget maîtrisé, communication claire</strong>. Vous n'avez pas à vous soucier des détails techniques — c'est précisément mon rôle.
            </p>
            <p>
              Je travaille entièrement à distance, avec des clients partout en France. Je prends en charge l'intégralité du projet : écoute de vos besoins, conception, développement et mise en ligne. Et je reste disponible après la livraison.
            </p>
          </div>
        </ScrollReveal>

        <!-- Stats -->
        <ScrollReveal class="lg:col-span-2">
          <div class="grid grid-cols-3 lg:grid-cols-1 gap-6">
            {stats.map((stat) => (
              <div class="text-center lg:text-left p-4 rounded-xl bg-card dark:bg-[var(--color-dark-card)] border border-default dark:border-[var(--color-dark-border)]">
                <div class="text-3xl lg:text-4xl font-bold text-accent mb-1">{stat.value}</div>
                <div class="text-sm text-text-muted dark:text-[var(--color-dark-text-muted)]">{stat.label}</div>
              </div>
            ))}
          </div>
        </ScrollReveal>
      </div>
    </div>
  </section>

  <!-- ===== SERVICES (aperçu) ===== -->
  <section class="py-20 lg:py-28 bg-surface-alt dark:bg-[var(--color-dark-surface)]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <ScrollReveal>
        <SectionHeading title="Mes services" subtitle="Des solutions adaptées à votre budget et vos objectifs." />
      </ScrollReveal>

      <div class="grid md:grid-cols-3 gap-8 mb-12">
        {services.map((service) => (
          <ScrollReveal>
            <Card title={service.title} description={service.description} icon={service.icon} mention="Sur devis" />
          </ScrollReveal>
        ))}
      </div>

      <ScrollReveal class="text-center">
        <Button href="/portfolio/services/" variant="secondary">
          En savoir plus
        </Button>
      </ScrollReveal>
    </div>
  </section>

  <!-- ===== PORTFOLIO (aperçu) ===== -->
  <section class="py-20 lg:py-28 bg-surface dark:bg-[var(--color-dark-bg)]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <ScrollReveal>
        <SectionHeading title="Mes réalisations" subtitle="Quelques projets récents pour des clients satisfaits." />
      </ScrollReveal>

      <div class="grid md:grid-cols-3 gap-8 mb-12">
        {portfolio.map((project) => (
          <ScrollReveal>
            <Card title={project.title} description={project.description} href={project.href} />
          </ScrollReveal>
        ))}
      </div>

      <ScrollReveal class="text-center">
        <Button href="/portfolio/portfolio/" variant="secondary">
          Voir tous les projets
        </Button>
      </ScrollReveal>
    </div>
  </section>

  <!-- ===== CTA FINAL ===== -->
  <section class="py-20 bg-gradient-to-r from-primary to-accent text-white text-center">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <ScrollReveal>
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Un projet en tête ?</h2>
        <p class="text-lg text-white/80 mb-8">
          Décrivez-moi votre besoin, je vous réponds sous 24h avec une première estimation gratuite.
        </p>
        <Button href="/portfolio/contact/" variant="primary" size="lg" class="bg-white text-primary hover:bg-white/90">
          Discutons de votre projet
        </Button>
      </ScrollReveal>
    </div>
  </section>
</BaseLayout>
