---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import ServiceCard from '../components/ServiceCard.astro';
import PortfolioCard from '../components/PortfolioCard.astro';
import CtaSection from '../components/CtaSection.astro';
import { services } from '../data/services';
import { projects } from '../data/portfolio';

const stats = [
  { value: 10, suffix: '+', label: "ans d'expérience" },
  { value: 100, suffix: '%', label: 'à distance' },
];
---

<BaseLayout
  title="Tristan Labbé — Développeur web freelance | Sites sur-mesure pour TPE et artisans"
  description="Développeur web full-stack indépendant. Création de sites vitrines et refonte pour TPE, artisans et associations. Devis gratuit."
>
  <!-- ===== HERO ===== -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-[#030712]">
    <!-- Animated gradient background -->
    <div class="absolute inset-0 animated-gradient bg-gradient-to-br from-[#030712] via-[#0F172A] to-[#1E3A5F]"></div>

    <!-- Grid pattern overlay -->
    <div class="absolute inset-0 opacity-[0.03] grid-overlay" aria-hidden="true"></div>

    <!-- Floating orbs -->
    <div class="absolute top-1/4 left-1/6 w-80 h-80 bg-accent/20 rounded-full blur-[120px] animate-pulse" aria-hidden="true"></div>
    <div class="absolute bottom-1/4 right-1/6 w-96 h-96 bg-purple-500/15 rounded-full blur-[120px] animate-pulse" style="animation-delay: 2s;" aria-hidden="true"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-accent/5 rounded-full blur-[150px]" aria-hidden="true"></div>

    <!-- Floating particles -->
    <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
      <div class="particle" style="left: 10%; animation-duration: 12s; animation-delay: -4s;"></div>
      <div class="particle" style="left: 20%; animation-duration: 15s; animation-delay: -10s;"></div>
      <div class="particle" style="left: 35%; animation-duration: 11s; animation-delay: -2s;"></div>
      <div class="particle" style="left: 50%; animation-duration: 14s; animation-delay: -8s;"></div>
      <div class="particle" style="left: 65%; animation-duration: 13s; animation-delay: -6s;"></div>
      <div class="particle" style="left: 80%; animation-duration: 16s; animation-delay: -12s;"></div>
      <div class="particle" style="left: 90%; animation-duration: 10s; animation-delay: -1s;"></div>
    </div>

    <div class="relative z-10 text-center px-4 sm:px-6 lg:px-8 max-w-5xl mx-auto">
      <!-- Badge -->
      <div class="hero-animate inline-flex items-center gap-2 px-4 py-2 rounded-full border border-emerald-400/30 bg-emerald-400/10 backdrop-blur-sm mb-8 shadow-[0_0_15px_rgba(52,211,153,0.15)]">
        <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse shadow-[0_0_6px_rgba(52,211,153,0.6)]" aria-hidden="true"></span>
        <span class="text-sm text-emerald-200/90">Disponible pour de nouveaux projets</span>
      </div>

      <h1 class="hero-animate hero-animate-delay-1 text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold text-white leading-[1.1] mb-8 tracking-tight">
        Des sites web sur-mesure<br />pour les <span class="gradient-text">TPE, artisans<br class="hidden sm:block" /> et associations</span>
      </h1>

      <p class="hero-animate hero-animate-delay-2 text-lg sm:text-xl text-white/70 max-w-2xl mx-auto mb-12 leading-relaxed">
        Votre activité mérite un vrai site. Je le conçois de A à Z — vous restez concentré sur votre métier.
      </p>

      <div class="hero-animate hero-animate-delay-3 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/portfolio/portfolio/" class="btn-glow group inline-flex items-center gap-2 px-8 py-4 bg-accent text-white font-semibold rounded-xl hover:bg-accent-hover shadow-lg shadow-accent/25 hover:shadow-accent/40 transition-all duration-300">
          Voir mes réalisations
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
        <a href="/portfolio/contact/" class="inline-flex items-center gap-2 px-8 py-4 border border-white/20 text-white font-semibold rounded-xl hover:bg-white/10 backdrop-blur-sm transition-all duration-300">
          Me contacter
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/30" aria-hidden="true">
      <span class="text-xs uppercase tracking-widest">Scroll</span>
      <div class="w-5 h-8 rounded-full border border-white/20 flex justify-center pt-1.5">
        <div class="w-1 h-2 bg-white/40 rounded-full animate-bounce"></div>
      </div>
    </div>
  </section>

  <!-- ===== Separator ===== -->
  <hr class="separator-gradient" />

  <!-- ===== À PROPOS ===== -->
  <section class="py-16 lg:py-24 bg-surface dark:bg-[var(--color-dark-bg)]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <ScrollReveal>
        <SectionHeading title="À propos" />
      </ScrollReveal>

      <div class="grid lg:grid-cols-5 gap-16 items-center">
        <ScrollReveal class="lg:col-span-3">
          <div class="space-y-6 text-lg text-text dark:text-[var(--color-dark-text)] leading-relaxed">
            <p>
              Développeur web full-stack avec plus de <strong>10 ans d'expérience</strong> en développement web et gestion de projets informatique, j'accompagne les TPE, artisans et associations qui veulent un site à la hauteur de leur activité. <strong>Délais respectés, budget maîtrisé, zéro jargon</strong> — vous n'avez pas à vous soucier des détails techniques.
            </p>
            <p>
              Je travaille 100% à distance avec des clients partout en France. De l'écoute de vos besoins à la mise en ligne, je suis votre <strong>interlocuteur unique</strong>. Et je reste disponible après la livraison.
            </p>
          </div>
        </ScrollReveal>

        <!-- Animated stats -->
        <ScrollReveal class="lg:col-span-2">
          <div class="grid grid-cols-2 lg:grid-cols-1 gap-6">
            {stats.map((stat) => (
              <div class="card-premium p-6 text-center lg:text-left">
                <div class="flex items-baseline gap-1 justify-center lg:justify-start">
                  <span class="text-4xl lg:text-5xl font-bold text-accent-text dark:text-accent-text-dark counter" data-target={stat.value}>{stat.value}</span>
                  <span class="text-2xl lg:text-3xl font-bold text-accent-text dark:text-accent-text-dark">{stat.suffix}</span>
                </div>
                <div class="text-sm text-text-muted dark:text-[var(--color-dark-text-muted)] mt-2">{stat.label}</div>
              </div>
            ))}
          </div>
        </ScrollReveal>
      </div>

      <!-- Compétences techniques -->
      <ScrollReveal class="mt-16">
        <h3 class="text-sm font-semibold uppercase tracking-widest text-text-muted dark:text-[var(--color-dark-text-muted)] mb-8 text-center">Technologies maîtrisées</h3>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
          {[
            { name: 'HTML / CSS', desc: 'Structure & design web', src: '/portfolio/images/logos/html5.svg', alt: 'Logo HTML5' },
            { name: 'PHP', desc: 'Langage back-end', src: '/portfolio/images/logos/php.svg', alt: 'Logo PHP' },
            { name: 'Symfony', desc: 'Framework PHP', src: '/portfolio/images/logos/symfony.svg', alt: 'Logo Symfony', darkInvert: true },
            { name: 'Drupal', desc: 'CMS flexible', src: '/portfolio/images/logos/drupal.svg', alt: 'Logo Drupal' },
            { name: 'WordPress', desc: 'CMS populaire', src: '/portfolio/images/logos/wordpress.svg', alt: 'Logo WordPress' },
            { name: 'Astro', desc: 'Framework moderne', src: '/portfolio/images/logos/astro.svg', alt: 'Logo Astro', darkInvert: true },
            { name: 'RGAA', desc: 'Accessibilité numérique', src: '/portfolio/images/logos/dinum.webp', alt: 'Logo DINUM' },
          ].map((skill) => (
            <div class="card-premium group flex items-center gap-4 p-4">
              <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-surface-alt dark:bg-[var(--color-dark-bg)] flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                <img src={skill.src} alt={skill.alt} width="32" height="32" class:list={['w-8 h-8 object-contain', skill.darkInvert && 'dark:invert']} loading="lazy" />
              </div>
              <div>
                <div class="font-semibold text-sm text-primary dark:text-white">{skill.name}</div>
                <div class="text-xs text-text-muted dark:text-[var(--color-dark-text-muted)]">{skill.desc}</div>
              </div>
            </div>
          ))}
        </div>
      </ScrollReveal>
    </div>
  </section>

  <hr class="separator-gradient" />
  <section class="py-16 lg:py-24 bg-surface-alt dark:bg-[var(--color-dark-surface)]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <ScrollReveal>
        <SectionHeading title="Mes services" subtitle="Création ou refonte — chaque projet est cadré et chiffré." />
      </ScrollReveal>

      <div class="grid md:grid-cols-3 gap-8 mb-16 stagger-children">
        {services.map((service) => (
          <ScrollReveal>
            <ServiceCard {...service} />
          </ScrollReveal>
        ))}
      </div>

      <ScrollReveal class="text-center">
        <a href="/portfolio/services/" class="btn-glow group inline-flex items-center gap-2 px-6 py-3 bg-primary text-white font-semibold rounded-xl hover:bg-primary-light shadow-lg shadow-primary/20 transition-all duration-300">
          Découvrir mes services
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </ScrollReveal>
    </div>
  </section>

  <hr class="separator-gradient" />

  <!-- ===== PORTFOLIO ===== -->
  <section class="py-16 lg:py-24 bg-surface dark:bg-[var(--color-dark-bg)]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <ScrollReveal>
        <SectionHeading title="Mes réalisations" subtitle="Des sites livrés, en ligne et fonctionnels." />
      </ScrollReveal>

      <div class="grid md:grid-cols-3 gap-8 mb-16 stagger-children">
        {projects.map((project) => (
          <ScrollReveal>
            <PortfolioCard {...project} />
          </ScrollReveal>
        ))}
      </div>

      <ScrollReveal class="text-center">
        <a href="/portfolio/portfolio/" class="btn-glow group inline-flex items-center gap-2 px-6 py-3 bg-primary text-white font-semibold rounded-xl hover:bg-primary-light shadow-lg shadow-primary/20 transition-all duration-300">
          Voir tous les projets
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </ScrollReveal>
    </div>
  </section>

  <!-- ===== CTA FINAL ===== -->
  <CtaSection
    title="Un projet en tête ?"
    subtitle="Je vous réponds rapidement avec une estimation gratuite."
    buttonText="Discutons de votre projet"
  />
</BaseLayout>

<!-- Animated counter script -->
<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var counters = document.querySelectorAll('.counter');
    if (!counters.length) return;
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (!entry.isIntersecting) return;
        var el = entry.target;
        var target = parseInt(el.getAttribute('data-target'), 10);
        var duration = 1500;
        var start = 0;
        var startTime = null;
        function step(timestamp) {
          if (!startTime) startTime = timestamp;
          var progress = Math.min((timestamp - startTime) / duration, 1);
          var eased = 1 - Math.pow(1 - progress, 3); // easeOutCubic
          el.textContent = Math.floor(eased * target);
          if (progress < 1) requestAnimationFrame(step);
          else el.textContent = target;
        }
        requestAnimationFrame(step);
        observer.unobserve(el);
      });
    }, { threshold: 0.5 });
    counters.forEach(function(c) { observer.observe(c); });
  });
</script>
