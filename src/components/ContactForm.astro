---
interface Props {
  formspreeId?: string;
}

const { formspreeId = 'xxxxx' } = Astro.props;
---

<form
  id="contact-form"
  action={`https://formspree.io/f/${formspreeId}`}
  method="POST"
  class="max-w-2xl mx-auto space-y-6"
>
  <!-- Honeypot anti-spam -->
  <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" />

  <div>
    <label for="name" class="block text-sm font-medium text-text dark:text-[var(--color-dark-text)] mb-2">
      Nom
    </label>
    <input
      type="text"
      id="name"
      name="name"
      required
      autocomplete="name"
      class="w-full px-4 py-3 rounded-lg border border-default dark:border-[var(--color-dark-border)] bg-card dark:bg-[var(--color-dark-card)] text-text dark:text-[var(--color-dark-text)] focus:ring-2 focus:ring-accent focus:border-transparent transition-colors"
      placeholder="Votre nom"
    />
  </div>

  <div>
    <label for="email" class="block text-sm font-medium text-text dark:text-[var(--color-dark-text)] mb-2">
      Email
    </label>
    <input
      type="email"
      id="email"
      name="email"
      required
      autocomplete="email"
      class="w-full px-4 py-3 rounded-lg border border-default dark:border-[var(--color-dark-border)] bg-card dark:bg-[var(--color-dark-card)] text-text dark:text-[var(--color-dark-text)] focus:ring-2 focus:ring-accent focus:border-transparent transition-colors"
      placeholder="votre@email.fr"
    />
  </div>

  <div>
    <label for="subject" class="block text-sm font-medium text-text dark:text-[var(--color-dark-text)] mb-2">
      Sujet
    </label>
    <input
      type="text"
      id="subject"
      name="subject"
      class="w-full px-4 py-3 rounded-lg border border-default dark:border-[var(--color-dark-border)] bg-card dark:bg-[var(--color-dark-card)] text-text dark:text-[var(--color-dark-text)] focus:ring-2 focus:ring-accent focus:border-transparent transition-colors"
      placeholder="Site vitrine, refonte, maintenance..."
    />
  </div>

  <div>
    <label for="message" class="block text-sm font-medium text-text dark:text-[var(--color-dark-text)] mb-2">
      Message
    </label>
    <textarea
      id="message"
      name="message"
      required
      rows="5"
      class="w-full px-4 py-3 rounded-lg border border-default dark:border-[var(--color-dark-border)] bg-card dark:bg-[var(--color-dark-card)] text-text dark:text-[var(--color-dark-text)] focus:ring-2 focus:ring-accent focus:border-transparent transition-colors resize-y"
      placeholder="Décrivez votre projet..."
    ></textarea>
  </div>

  <p class="text-xs text-text-muted dark:text-[var(--color-dark-text-muted)]">
    Vos données sont utilisées uniquement pour répondre à votre demande. <a href="/portfolio/mentions-legales/" class="underline hover:text-accent">Politique de confidentialité</a>.
  </p>

  <button
    type="submit"
    id="submit-btn"
    class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-3 bg-accent text-white font-semibold rounded-lg hover:bg-accent-hover shadow-md hover:shadow-lg transition-all duration-200 disabled:opacity-50 disabled:cursor-not-allowed"
  >
    <span id="btn-text">Envoyer mon projet</span>
    <svg id="btn-spinner" class="hidden w-5 h-5 ml-2 animate-spin" fill="none" viewBox="0 0 24 24">
      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
    </svg>
  </button>

  <!-- Status messages -->
  <div id="form-success" class="hidden p-4 rounded-lg bg-success/10 text-success font-medium text-sm">
    Merci ! Je vous réponds sous 24h avec une première estimation gratuite.
  </div>
  <div id="form-error" class="hidden p-4 rounded-lg bg-error/10 text-error font-medium text-sm">
    Une erreur est survenue. Veuillez réessayer ou me contacter directement par email.
  </div>
</form>

<script is:inline>
  (function() {
    var form = document.getElementById('contact-form');
    if (!form) return;

    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var btn = document.getElementById('submit-btn');
      var btnText = document.getElementById('btn-text');
      var spinner = document.getElementById('btn-spinner');
      var successMsg = document.getElementById('form-success');
      var errorMsg = document.getElementById('form-error');

      btn.disabled = true;
      btnText.textContent = 'Envoi en cours...';
      spinner.classList.remove('hidden');
      successMsg.classList.add('hidden');
      errorMsg.classList.add('hidden');

      fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { 'Accept': 'application/json' },
      })
      .then(function(response) {
        if (response.ok) {
          form.reset();
          successMsg.classList.remove('hidden');
        } else {
          errorMsg.classList.remove('hidden');
        }
      })
      .catch(function() {
        errorMsg.classList.remove('hidden');
      })
      .finally(function() {
        btn.disabled = false;
        btnText.textContent = 'Envoyer mon projet';
        spinner.classList.add('hidden');
      });
    });
  })();
</script>
