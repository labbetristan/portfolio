---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="text-center mb-16">
  <h2 class="text-3xl md:text-4xl font-bold text-primary dark:text-white mb-4">
    {title}
  </h2>
  <div class="w-16 h-1 mx-auto rounded-full bg-gradient-to-r from-accent to-purple-500 mb-6"></div>
  {subtitle && (
    <p class="text-lg text-text-muted dark:text-[var(--color-dark-text-muted)] max-w-2xl mx-auto">
      {subtitle}
    </p>
  )}
</div>
