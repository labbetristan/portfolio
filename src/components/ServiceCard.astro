---
interface Props {
  title: string;
  description: string;
  icon: string;
}

const { title, description, icon } = Astro.props;
---

<a href={`/portfolio/contact/?sujet=${encodeURIComponent(title)}`} class="card-premium p-8 block group cursor-pointer">
  <div class="icon-glow w-14 h-14 rounded-xl bg-accent/10 flex items-center justify-center mb-6 text-accent" set:html={icon} />
  <h3 class="text-xl font-bold text-primary dark:text-white mb-3 group-hover:text-accent transition-colors">{title}</h3>
  <p class="text-text-muted dark:text-[var(--color-dark-text-muted)] text-sm leading-relaxed mb-5">{description}</p>
  <span class="inline-flex items-center gap-1 text-xs font-semibold text-accent-text dark:text-accent-text-dark bg-accent/10 px-3 py-1.5 rounded-full group-hover:bg-accent group-hover:text-white transition-colors">
    Demander un devis
    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
  </span>
</a>
